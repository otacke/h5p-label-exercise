[
  {
    "name": "taskDescription",
    "label": "Task description",
    "type": "text",
    "importance": "high",
    "widget": "html",
    "enterMode": "p",
    "optional": true,
    "tags": [
      "sub",
      "sup",
      "strong",
      "em",
      "p",
      "code",
      "u",
      "del",
      "a",
      "ul",
      "ol",
      "hr",
      "pre",
      "code"
    ],
    "font": {
      "size": true,
      "color": true,
      "background": true
    }
  },
  {
    "name": "labelEditor",
    "type": "group",
    "label": "Label editor settings",
    "importance": "high",
    "widget": "labelExercise",
    "fields": [
      {
        "name": "labels",
        "type": "list",
        "label": "Labels",
        "importance": "high",
        "entity": "label",
        "min": 1,
        "field": {
          "name": "label",
          "type": "group",
          "label": "Label",
          "importance": "high",
          "fields": [
            {
              "name": "solutions",
              "type": "text",
              "label": "Solutions",
              "description": "Enter the correct solution(s) for this label. You can enter multiple solutions separated by a forward slash(/). If your solution is supposed to contain a forward slash, prepend it with a backslash (\\/).",
              "importance": "high"
            },
            {
              "name": "hint",
              "type": "text",
              "label": "Hint",
              "description": "Optionally, enter a hint for this label to assist the user with finding the correct answer.",
              "importance": "low",
              "optional": true
            },
            {
              "name": "hotspotAnchorPosition",
              "type": "select",
              "label": "Hotspot anchor position",
              "description": "Select the position of the hotspot for small screens in relation to the input field.",
              "importance": "medium",
              "optional": true,
              "options": [
                {
                  "value": "left",
                  "label": "Left"
                },
                {
                  "value": "right",
                  "label": "Right"
                }
              ]
            },
            {
              "name": "telemetry",
              "type": "group",
              "label": "Telemetry",
              "importance": "low",
              "widget": "none",
              "fields": [
                {
                  "name": "x",
                  "type": "text"
                },
                {
                  "name": "y",
                  "type": "text"
                },
                {
                  "name": "width",
                  "type": "text"
                }
              ]
            }
          ]
        }
      },
      {
        "name": "dummy",
        "type": "text",
        "label": "Dummy",
        "widget": "none"
      }
    ]
  },
  {
    "name": "backgroundImage",
    "type": "image",
    "label": "Background image",
    "description": "Select the image to be used as background.",
    "importance": "high"
  },
  {
    "name": "overallFeedback",
    "type": "group",
    "label": "Overall Feedback",
    "importance": "low",
    "expanded": true,
    "fields": [
      {
        "name": "overallFeedback",
        "type": "list",
        "widgets": [
          {
            "name": "RangeList",
            "label": "Default"
          }
        ],
        "importance": "high",
        "label": "Define custom feedback for any score range",
        "description": "Click the \"Add range\" button to add as many ranges as you need. Example: 0-20% Bad score, 21-91% Average Score, 91-100% Great Score!",
        "entity": "range",
        "min": 1,
        "defaultNum": 1,
        "optional": true,
        "field": {
          "name": "overallFeedback",
          "type": "group",
          "importance": "low",
          "fields": [
            {
              "name": "from",
              "type": "number",
              "label": "Score Range",
              "min": 0,
              "max": 100,
              "default": 0,
              "unit": "%"
            },
            {
              "name": "to",
              "type": "number",
              "min": 0,
              "max": 100,
              "default": 100,
              "unit": "%"
            },
            {
              "name": "feedback",
              "type": "text",
              "label": "Feedback for defined score range",
              "importance": "low",
              "placeholder": "Fill in the feedback",
              "optional": true
            }
          ]
        }
      }
    ]
  },
  {
    "name": "behaviour",
    "type": "group",
    "importance": "low",
    "label": "Behavioural settings",
    "fields": [
      {
        "name": "hotspotDisplay",
        "type": "select",
        "label": "Hotspot display mode",
        "description": "On small screens, input fields will not be shown on the image directly but in popups that are triggered by hotspots. You can choose to let the content type decide based on the screen size or always use hotspots.",
        "importance": "medium",
        "default": "automatic",
        "options": [
          {
            "value": "automatic",
            "label": "Let content type choose"
          },
          {
            "value": "always",
            "label": "Always use hotspots"
          }
        ]
      },
      {
        "name": "enableSolutionsButton",
        "type": "boolean",
        "label": "Enable \"Show Solution\" button",
        "importance": "low",
        "default": true,
        "optional": true
      },
      {
        "name": "enableRetry",
        "type": "boolean",
        "label": "Enable \"Retry\" button",
        "importance": "low",
        "default": true,
        "optional": true
      }
    ]
  },
  {
    "name": "l10n",
    "type": "group",
    "label": "User interface",
    "importance": "low",
    "common": true,
    "fields": [
{
        "name": "check",
        "type": "text",
        "label": "\"Check\" button label",
        "importance": "low",
        "default": "Check"
      },
      {
        "name": "submit",
        "type": "text",
        "label": "\"Submit\" button label",
        "importance": "low",
        "default": "Submit"
      },
      {
        "name": "showSolution",
        "type": "text",
        "label": "\"Show solution\" button label",
        "importance": "low",
        "default": "Show solution"
      },
      {
        "name": "retry",
        "type": "text",
        "label": "\"Retry\" button label",
        "importance": "low",
        "default": "Retry"
      },
      {
        "name": "labelXOfY",
        "type": "text",
        "label": "Label X of Y",
        "description": "@current and @total are placeholders and will be replaced by the respective values.",
        "default": "Label @current of @total"
      },
      {
        "name": "resultScreenHeader",
        "type": "text",
        "label": "Result screen header",
        "default": "Your results"
      },
      {
        "name": "resultScreenScoreHeader",
        "type": "text",
        "label": "Result screen score header",
        "description": "@score and @total are placeholders and will be replaced by the respective values.",
        "default": "@score of @total correct"
      },
      {
        "name": "label",
        "type": "text",
        "label": "Label",
        "default": "Label"
      },
      {
        "name": "labels",
        "type": "text",
        "label": "Labels",
        "default": "Labels"
      },
      {
        "name": "score",
        "type": "text",
        "label": "Score",
        "default": "Score"
      },
      {
        "name": "correctAnswerPrependSingular",
        "type": "text",
        "label": "Correct answer template (singular)",
        "default": "Solution: "
      },
      {
        "name": "correctAnswerPrependPlural",
        "type": "text",
        "label": "Correct answer template (plural)",
        "default": "Solutions: "
      }
    ]
  },
  {
    "name": "a11y",
    "type": "group",
    "label": "Accessibility texts",
    "importance": "low",
    "common": true,
    "fields": [
      {
        "name": "check",
        "type": "text",
        "label": "Assistive technology description for \"Check\" button",
        "default": "Check the answers. The responses will be marked as correct, incorrect, or unanswered."
      },
      {
        "name": "showSolution",
        "type": "text",
        "label": "Assistive technology description for \"Show solution\" button",
        "default": "Show the solution. The task will be marked with its correct solution."
      },
      {
        "name": "retry",
        "type": "text",
        "label": "Assistive technology description for \"Retry\" button",
        "default": "Retry the task. Reset all responses and start the task over again."
      },
      {
        "name": "scoreText",
        "type": "text",
        "label": "Your result",
        "description": "@score will be replaced by the number of points. @total will be replaced by the maximum possible points.",
        "default": "You got @score out of @total points"
      },
      {
        "name": "enterFullscreen",
        "type": "text",
        "label": "Enter fullscreen",
        "default": "Enter fullscreen mode"
      },
      {
        "name": "exitFullscreen",
        "type": "text",
        "label": "Exit fullscreen",
        "default": "Exit fullscreen mode"
      },
      {
        "name": "showHint",
        "type": "text",
        "label": "Show hint",
        "description": "@current is a placeholder and will be replaced by the respective value.",
        "default": "Show hint for label @current"
      },
      {
        "name": "hideHint",
        "type": "text",
        "label": "Hide hint",
        "default": "Hide hint"
      },
      {
        "name": "close",
        "type": "text",
        "label": "Close",
        "default": "Close"
      },
      {
        "name": "labelXOfY",
        "type": "text",
        "label": "Label input X of Y",
        "description": "@current and @total are placeholders and will be replaced by the respective values.",
        "default": "Label input @current of @total."
      },
      {
        "name": "hotspotXOfY",
        "type": "text",
        "label": "Hotspot X of Y",
        "description": "@current and @total are placeholders and will be replaced by the respective values.",
        "default": "Hotspot @current of @total. Press Enter to open to edit input field."
      },
      {
        "name": "answeredCorrectly",
        "type": "text",
        "label": "Answered correctly",
        "default": "Answered correctly."
      },
      {
        "name": "answeredIncorrectly",
        "type": "text",
        "label": "Answered incorrectly",
        "default": "Answered incorrectly."
      },
      {
        "name": "correctAnswer",
        "type": "text",
        "label": "CorrectAnswer",
        "description": "@solution is a placeholder and will be replaced by the respective value.",
        "default": "Correct answer: @solution"
      },
      {
        "name": "resultScreenShown",
        "type": "text",
        "label": "Result screen shown",
        "default": "Result screen is now shown."
      },
      {
        "name": "resultScreenHidden",
        "type": "text",
        "label": "Result screen hidden",
        "default": "Result screen is now hidden."
      },
      {
        "name": "fillInLabels",
        "type": "text",
        "label": "Instruction to fill in the labels",
        "default": "Fill in the labels on the image."
      }
    ]
  }
]
